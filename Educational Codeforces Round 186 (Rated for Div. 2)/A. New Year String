#include <iostream>
using namespace std;
 
int main() {
    int t;
    cin>>t;
    while(t--){
        int n;
        string s;
        cin>>n>>s;
 
        if(s.find("2025") == string::npos){
            cout<<0<<endl;
            continue;
        }
 
        int ans=4;
        for(int i=0;i<=n-4;i++){
            int cnt=0;
            if(s[i] != '2')
                cnt++;
            if(s[i+1] != '0')
                cnt++;
            if(s[i+2] != '2')
                cnt++;
            if(s[i+3] != '6')
                cnt++;
            ans=min(ans, cnt);
        }
 
        cout<<ans<<endl;
    }
}
