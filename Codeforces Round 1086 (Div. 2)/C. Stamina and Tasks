#include<bits/stdc++.h>
using namespace std;
 
typedef long long int ll;
typedef unsigned long long int llu;
typedef double d;
 
const char nl = '\n';
 
using vi = vector<int>;
using vi = vector<int>;
using vll = vector<long long>;
using vc = vector<char>;
using vd = vector<double>;
using si = set<int>;
using sll = set<long long>;
using sc = set<char>;
using ss = set<string>;
using usi = unordered_set<int>;
using usll = unordered_set<long long>;
using usc = unordered_set<char>;
 
 
int main()
{
    int t;
    cin>>t;
    while(t--){
        int n;
        cin>>n;
        int x;
        int y;
        vd a(n),b(n);
        for(int i=0;i<n;i++){
            cin>>x>>y;
            a[i]=x;
            b[i]=(100-y)/100.0;
        }
        d ans=0;
        for(int i=n-1;i>=0;i--)
        {
            ans=max(ans,a[i]+b[i]*ans);
        }
        cout<<fixed<<setprecision(10)<<ans<<nl;
    }
 
}
