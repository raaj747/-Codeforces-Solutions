// ================= DSU =================
struct DSU {
    vi parent, sz;
    DSU(int n) {
        parent.resize(n+1);
        sz.resize(n+1, 1);
        iota(all(parent), 0);
    }
    int find(int x) {
        if(parent[x] == x) return x;
        return parent[x] = find(parent[x]);
    }
    void unite(int a, int b) {
        a = find(a);
        b = find(b);
        if(a != b) {
            if(sz[a] < sz[b]) swap(a,b);
            parent[b] = a;
            sz[a] += sz[b];
        }
    }
};
 
// ================= GRAPH =================
void bfs(int start, vector<vi> &adj, vi &vis)
{
    queue<int> q;
    q.push(start);
    vis[start] = 1;
 
    while(!q.empty())
    {
        int u = q.front(); q.pop();
        for(auto v : adj[u])
        {
            if(!vis[v])
            {
                vis[v] = 1;
                q.push(v);
            }
        }
    }
}
 
void dfs(int u, vector<vi> &adj, vi &vis)
{
    vis[u] = 1;
    for(auto v : adj[u])
        if(!vis[v]) dfs(v, adj, vis);
}
 
// ================= DIJKSTRA =================
vector<ll> dijkstra(int n, vector<vector<pair<int,int>>> &adj, int src)
{
    vector<ll> dist(n+1, LLONG_MAX);
    priority_queue<pair<ll,ll>, vector<pair<ll,ll>>, greater<pair<ll,ll>>> pq;
 
    dist[src] = 0;
    pq.push({0, src});
 
    while(!pq.empty())
    {
        auto [d, u] = pq.top(); pq.pop();
        if(d > dist[u]) continue;
 
        for(auto [v, w] : adj[u])
        {
            if(dist[v] > d + w)
            {
                dist[v] = d + w;
                pq.push({dist[v], v});
            }
        }
    }
    return dist;
}
 
