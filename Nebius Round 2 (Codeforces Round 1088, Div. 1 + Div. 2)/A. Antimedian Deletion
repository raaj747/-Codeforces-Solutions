ll gcd(ll a, ll b) { return __gcd(a, b); }
ll lcm(ll a, ll b) { return (a / gcd(a, b)) * b; }
 
ll binpow(ll a, ll b, ll mod = mod1)
{
    a %= mod;
    ll res = 1;
    while(b)
    {
        if(b & 1) res = (res * a) % mod;
        a = (a * a) % mod;
        b >>= 1;
    }
    return res;
}
 
ll modinv(ll a, ll mod = mod1)
{
    return binpow(a, mod - 2, mod);
}
 
 
