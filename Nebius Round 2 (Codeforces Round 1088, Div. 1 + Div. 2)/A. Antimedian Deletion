const int N = 1e6+5;
vb is_prime(N, true);
 
void sieve()
{
    is_prime[0] = is_prime[1] = false;
    for(int i=2;i*i<N;i++)
        if(is_prime[i])
            for(int j=i*i;j<N;j+=i)
                is_prime[j] = false;
}
 
