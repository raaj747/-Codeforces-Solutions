#include<bits/stdc++.h>
using namespace std;
 
int main(){
    int t;
    cin >> t;
    while(t--){
        int a,b,c;
        cin>>a>>b>>c;
 
        int sum=0;
        for(int i=0;i<a;i++)
        {
            int n;
            cin>>n;
            sum+=n;
        }
 
        if(b>=sum && (b-sum)%c == 0)
        {
            cout<<"YES"<<endl;
        }
        else
        {
            cout<<"NO"<<endl;
        }
    }
}
