#include<bits/stdc++.h>
using namespace std;
 
void solve(){
    int t;
    cin>>t;
    while(t--){
        int n;
        cin>>n;
        vector<int> p(n);
        for(int i=0;i<n i++) 
            cin>> p[i];
 
        int l=0;
        while(l<n-1 && p[l]==n-l) 
            l++; 
 
        int r=l;
        for(int i=l;i<n;i++){
            if(p[i]>p[r])
              r=i;
        }
 
        reverse(p.begin() + l, p.begin()+r+1);
 
        for(int i=0;i<n;i++){
            cout<<p[i] <<" ";
        }
        cout<<endl;
    }
}
 
int main(){
    ios::sync_with_stdio(false);
    cin.tie(nullptr);
    solve();
    return 0;
}
