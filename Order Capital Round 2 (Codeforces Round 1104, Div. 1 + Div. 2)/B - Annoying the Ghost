#include<bits/stdc++.h>
using namespace std;

typedef long long ll;
const char nl = '\n';
using vi = vector<int>;
using vll = vector<long long>;
using vs = vector<string>;
using si = set<int>;
using sll = set<long long>;
using st = stack<int>;

int main()
{
    int t;
    cin>>t;
    while(t--)
    {

        int n;
        cin>>n;

        vll a(n),b(n);
        for(int i=0;i<n;i++)
        {
            cin>>a[i];
        }
        for(int i=0;i<n;i++)
        {
            cin>>b[i];
        }

        vi ans(n,0);
        vi v;
        bool ok=true;
        for(int i=0;i<n;i++)
        {

            int res=-1;
            for(int j=0;j<n;j++)
            {
                if(!ans[j]&&a[j]<=b[i])
                {
                    res=j;
                    ans[j]=1;
                    break;
                }



            }

            if(res==-1)
            {
                ok=false;
                break;



            }
            v.push_back(res);
        }

        if(!ok)
        {
            cout<<-1<<nl;
            continue;

        }

        ll cnt=0;
        for(int i=0;i<n;i++)
        {
            for(int j=i+1;j<n;j++)
            {
                if(v[i]>v[j])
                {
                    cnt++;

                }


            }


        }

        cout<<cnt<<nl;





    }

}
