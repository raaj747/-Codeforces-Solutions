#include<bits/stdc++.h>
using namespace std;
 
typedef long long int ll;
typedef unsigned long long int llu;
 
int main(){
    int t;
    cin>>t;
    while(t--)
    {
        int n;
        cin>>n;
        string s;
        cin>>s;
 
        int ans=0;
        for(int i=0;i<n;i++){
            string r=s.substr(i)+s.substr(0,i);
 
            int b=1;
            for(int j=1;j<n;j++){
                if(r[j] != r[j - 1]){
                    b++;
                }
            }
 
            ans=max(ans,b);
        }
 
        cout<<ans<<endl;
    }
 
 
}
