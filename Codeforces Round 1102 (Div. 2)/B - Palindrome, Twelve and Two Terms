#include<bits/stdc++.h>
using namespace std;

typedef long long ll;
const char nl = '\n';
using vi = vector<int>;
using vll = vector<long long>;
using vs = vector<string>;
using si = set<int>;
using sll = set<long long>;
using st = stack<int>;

int main()
{
    int t;
    cin>>t;
    while(t--)
    {

        ll n;
        cin>>n;

        bool ok=false;
        for (ll i=0;i<=n && i<=2000000;i++)
        {
            ll b=n-i;

            if(b%12!=0)
            {
                continue;
            }

            ll x=i;
            ll ans=0;
            ll tmp=i;

            while(tmp>0)
            {
                ans=ans*10+(tmp%10);
                tmp/=10;

            }

            if(x==ans)
            {
                cout<<i<<" "<<b<<nl;
                ok=true;
                break;
            }


        }

        if(!ok)
        {
            cout<<-1<<nl;
        }










    }

}
