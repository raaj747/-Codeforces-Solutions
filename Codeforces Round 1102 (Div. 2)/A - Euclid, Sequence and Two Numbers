#include<bits/stdc++.h>
using namespace std;

typedef long long ll;
const char nl = '\n';
using vi = vector<int>;
using vll = vector<long long>;
using vs = vector<string>;
using si = set<int>;
using sll = set<long long>;
using st = stack<int>;

int main()
{
    int t;
    cin>>t;
    while(t--)
    {

        int n;
        cin>>n;

        vll a(n);
        for(int i=0;i<n;i++)
        {
            cin>>a[i];
        }

        sort(a.rbegin(),a.rend());
        bool ok=true;
        for(int i=0;i<n-2;i++)
        {

            if(a[i+2]!=a[i]%a[i+1])
            {
                ok=false;
                break;

            }



        }

        if(ok)
        {
            cout<<a[0]<<" "<<a[1]<<nl;
        }
        else
        {
            cout<<-1<<nl;
        }







    }

}
