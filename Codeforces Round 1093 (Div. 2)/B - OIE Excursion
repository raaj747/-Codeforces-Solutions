#include<bits/stdc++.h>
using namespace std;
 
typedef long long ll;
const char nl='\n';
using vi = vector<int>;
using vll = vector<long long>;
 
int main()
{
    int t;
    cin >> t;
    while (t--)
    {
        int n,m;
        cin>>n>>m;
 
        vi v(n);
        for(int i=0;i<n;i++)
        {
            cin>>v[i];
        }
 
        int cnt=1;
        bool ok=true;
 
        for(int i=1;i<n;i++)
        {
            if(v[i]==v[i-1])
            {
                cnt++;
            }
            else
            {
                if(cnt>=m)
                {
                    ok=false;
                    break;
                }
                cnt=1;
            }
        }
 
        if(cnt>=m)
        {
            ok=false;
        }
 
        if(ok)
        {
            cout<<"YES"<<nl;
 
        }
        else
        {
            cout<<"NO"<<nl;
        }
 
 
 
    }
 
}
