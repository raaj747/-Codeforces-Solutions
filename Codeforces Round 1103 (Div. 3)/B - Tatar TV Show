#include<bits/stdc++.h>
using namespace std;

typedef long long ll;
const char nl = '\n';
using vi = vector<int>;
using vll = vector<long long>;
using vs = vector<string>;
using si = set<int>;
using sll = set<long long>;
using st = stack<int>;

int main()
{
    int t;
    cin>>t;
    while(t--)
    {

        int n,k;
        cin>>n>>k;

        string s;
        cin>>s;

        bool ok=true;
        for(int i=0;i<k;i++)
        {

            int cnt=0;
            for(int j=i;j<n;j+=k)
            {
                if(s[j]=='1')
                {
                    cnt++;
                }



            }

            if(cnt&1)
            {
                ok=false;
                break;
            }




        }

        if(ok)
        {
            cout<<"YES"<<nl;
        }
        else
        {
            cout<<"NO"<<nl;
        }












    }

}
