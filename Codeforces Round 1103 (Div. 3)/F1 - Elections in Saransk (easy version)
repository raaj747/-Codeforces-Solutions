#include<bits/stdc++.h>
using namespace std;

typedef long long ll;
const char nl = '\n';
using vi = vector<int>;
using vll = vector<long long>;
using vs = vector<string>;
using si = set<int>;
using sll = set<long long>;
using st = stack<int>;


const int MOD=1e9+7;
const int N=5e5+5;

int spf[N];
int cnt[N];

void sieve(){
    for(int i=2;i<N;i++)
    {

        if(!spf[i])
        {

            for(int j=i;j<N;j+=i)
            {
                if (!spf[j])
                {
                    spf[j]=i;

                }



            }



        }




    }


}


int main()
{

    sieve();

    int t;
    cin>>t;
    while(t--)
    {

        int n,x;
        cin>>n>>x;

        vi used;
        vi a(n);
        for(int i=0;i<n;i++)
        {
            cin>>a[i];
        }

        for(int i=0;i<n;i++)
        {
            int v=a[i];
            while(v>1)
            {
                int p=spf[v];
                int c=0;
                while(v%p==0)
                {
                    v/=p;
                    c++;


                }
                if(cnt[p]==0)
                {
                    used.push_back(p);
                }
                cnt[p]+=c;


            }


        }

        ll ans=1;
        for(auto i:used)
        {
            ans=ans*(cnt[i]+1)%MOD;
            cnt[i]=0;


        }

        cout<<ans<<nl;












    }

}
