#include<bits/stdc++.h>
using namespace std;
 
typedef long long int ll;
typedef unsigned long long int llu;
 
const char nl='\n';
 
int main()
{
   int t;
   cin>>t;
   while(t--)
   {
        int n;
        cin>>n;
        vector<int> a(n);
        for(int i=0;i<n;i++){
            cin>>a[i];
        }
 
        int pos=-1;
        for(int i=0;i<n;i++){
            if(a[i] == n){
                pos=i;
                break;
            }
        }
 
        if(pos!=0){
            swap(a[0],a[pos]);
        }
 
        for(int i=0;i<n;i++){
            cout<<a[i]<< " ";
        }
        cout<<nl;
    }
 
}
