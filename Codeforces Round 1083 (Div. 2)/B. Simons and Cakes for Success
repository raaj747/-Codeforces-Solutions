#include<bits/stdc++.h>
using namespace std;
 
typedef long long int ll;
typedef unsigned long long int llu;
 
const char nl='\n';
 
int main()
{
   int t;
   cin>>t;
   while(t--)
   {
        ll n;
        cin>>n;
        ll temp=n;
        ll k=1;
        for(ll i=2;i*i<=temp;i++){
            if(temp%i == 0){
                k*=i;
                while(temp%i == 0){
                    temp/=i;
                }
            }
        }
 
        if(temp>1){
            k*=temp;
        }
 
        cout<<k<<nl;
    }
 
}
