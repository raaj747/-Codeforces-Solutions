#include<bits/stdc++.h>
using namespace std;

typedef long long ll;
const char nl = '\n';
using vi = vector<int>;
using vll = vector<long long>;
using si = set<int>;
using sll = set<long long>;
using st = stack<int>;

static const long long MOD=676767677;

int main()
{

    int t;
    cin>>t;
    while(t--)
    {
        int n;
        cin>>n;

        vi a(n);
        for(int i=0;i<n;i++)
        {
            cin>>a[i];
        }

        ll ans=0;
        int x=-1;

        for(int i=0;i<n;i++)
        {
            if(a[i]>1)
            {
                ans+=a[i];
                x=i;
            }
        }


        if(x==-1)
        {
            ans=1;

        }
        else
        {

            if(x<n-1)
            {
                ans+=1;
            }


        }

        cout<<(ans%MOD)<<nl;


    }





}
