#include<bits/stdc++.h>
using namespace std;

typedef long long ll;
const char nl = '\n';
using vi = vector<int>;
using vll = vector<long long>;
using si = set<int>;
using sll = set<long long>;
using st = stack<int>;

int main()
{

    int t;
    cin>>t;
    while(t--)
    {
        int n;
        cin>>n;

        vi v(n);
        for(int i=0;i<n;i++)
        {
            cin>>v[i];
        }


        ll ans=0;
        for(int i=0;i<n-1;i++)
        {
            int a=v[i];
            int b=v[i+1];

            int mn=min(a,b);
            int mx=max(a,b);
            int diff=mx-mn;

            if(mn%diff==0)
            {
                ans++;
            }

        }

        cout<<ans<<nl;
    }

}
