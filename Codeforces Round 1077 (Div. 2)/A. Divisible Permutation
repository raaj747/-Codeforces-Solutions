#include<bits/stdc++.h>
using namespace std;
 
int main()
{ 
    int t;
    cin >> t;
    while(t--){
        int n;
        cin>>n;
        vector<int> p={1,n};
        set<int>used={1,n};
 
        for(int i=n-2;i>0;--i){
            int prev=p.back();
            if(prev-i>=1 && prev-i<=n && used.find(prev-i)==used.end())
            {
                p.push_back(prev-i);
                used.insert(prev-i);
            }else{
                p.push_back(prev+i);
                used.insert(prev+i);
            }
        }
 
        reverse(p.begin(), p.end());
        for(int i=0;i<n;++i)
        {
            cout<<p[i]<<" ";
        }
        cout<<endl;
    }
}
