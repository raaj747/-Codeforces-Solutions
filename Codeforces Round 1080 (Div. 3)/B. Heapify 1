#include<bits/stdc++.h>
using namespace std;
 
typedef long long int ll;
typedef unsigned long long int  llu;
 
int main()
{
   int t;
   cin>>t;
   while(t--)
   {
        int n;
        cin>>n;
        vector<int> a(n+1);
        for(int i=1;i<=n;i++)
            cin>>a[i];
 
        bool change;
        do{
            change=false;
            for(int i=1;i<=n/2;i++){
                int j=2*i;
                if(j<=n && a[i]>a[j]){
                    swap(a[i],a[j]);
                    change=true;
                }
            }
        }while(change);
 
        bool st=true;
        for(int i=1;i<n;i++){
            if(a[i]>a[i+1]){
                st=false;
                break;
            }
        }
 
        cout<<(st?"YES":"NO")<<endl;
   }
 
}
