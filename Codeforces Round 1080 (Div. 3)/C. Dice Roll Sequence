#include<bits/stdc++.h>
using namespace std;
 
typedef long long int ll;
typedef unsigned long long int  llu;
 
 
int main(){
    ll t;
    cin>>t;
    while(t--)
    {
        int n;
        cin>>n;
 
        vector<int> a(n);
        for(int &x:a)
            cin>>x;
 
        int ans=0;
        for(int i=1;i<n;i++){
            if(a[i]+a[i-1] == 7 || a[i] == a[i-1]){
                ans++;
                i++;
            }
        }
 
        cout<<ans<<endl;
    }
 
 
}
