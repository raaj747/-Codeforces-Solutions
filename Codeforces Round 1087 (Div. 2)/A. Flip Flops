#include<bits/stdc++.h>
using namespace std;
 
typedef long long int ll;
typedef unsigned long long int llu;
typedef double d;
typedef string ss;
 
const char nl = '\n';
 
using vi = vector<int>;
using vll = vector<long long>;
using vc = vector<char>;
using vd = vector<double>;
using vb = vector<bool>;
using si = set<int>;
using sll = set<long long>;
using sc = set<char>;
using usi = unordered_set<int>;
using usll = unordered_set<long long>;
using usc = unordered_set<char>;
 
 
int main()
{
   int t;
   cin>>t;
   while(t--)
   {
        ll n;
        cin>>n;
        ll c;
        cin>>c;
        ll k;
        cin>>k;
 
        vll a(n);
        for(ll i=0;i<n;i++)
        {
            cin>>a[i];
        }
 
        sort(a.begin(),a.end());
        for(ll i=0;i<n;i++)
        {
            if(a[i]>c)
            {
                break;
            }
 
            ll add=min(k,c-a[i]);
            a[i]+=add;
            k-=add;
            c+=a[i];
        }
        cout<<c<<nl;
 
 
 
 
 
 
 
   }
 
}
 
 
