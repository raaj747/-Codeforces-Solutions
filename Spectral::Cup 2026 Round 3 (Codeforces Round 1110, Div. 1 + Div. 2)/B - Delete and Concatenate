#include<bits/stdc++.h>
using namespace std;

typedef long long ll;
const char nl = '\n';
using vi = vector<int>;
using vll = vector<long long>;
using vs = vector<string>;
using si = set<int>;
using sll = set<long long>;
using st = stack<int>;

int main()
{
    int t;
    cin>>t;
    while(t--)
    {

        ll n,c;
        cin>>n>>c;

        ll sum=0;
        vll a(n);
        for(int i=0;i<n;i++)
        {
            cin>>a[i];
            sum+=a[i];
        }

        sort(a.begin(),a.end());
        ll i=0;
        ll j=n-1;
        ll ans=sum-n*c;
        while(i<j && c>a[i])
        {
            ans+=c-a[i];
            i++;
            j--;

        }
        cout<<ans<<nl;







    }

}
