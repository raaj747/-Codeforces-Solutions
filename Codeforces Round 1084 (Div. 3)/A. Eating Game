#include<bits/stdc++.h>
using namespace std;
 
typedef long long int ll;
typedef unsigned long long int llu;
 
const char nl='\n';
 
int main()
{
   int t;
   cin>>t;
   while(t--)
   {
 
        int n;
        cin>>n;
        vector<int> a(n);
        int mx=0;
        for(int i=0;i<n;i++){
            cin>>a[i];
            mx=max(mx,a[i]);
        }
 
        int cnt=0;
        for(int i=0;i<n;i++){
            if(a[i] == mx)
                cnt++;
        }
 
        cout<<cnt<<nl;
 
 
 
 
   }
 
}
