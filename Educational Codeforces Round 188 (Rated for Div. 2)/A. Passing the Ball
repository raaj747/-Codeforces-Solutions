#include<bits/stdc++.h>
using namespace std;
 
typedef long long int ll;
typedef unsigned long long int llu;
typedef double d;
typedef string s;
 
const char nl = '\n';
 
using vi = vector<int>;
using vll = vector<long long>;
using vc = vector<char>;
using vd = vector<double>;
using vb = vector<bool>;
using si = set<int>;
using sll = set<long long>;
using sc = set<char>;
using ss = set<string>;
using usi = unordered_set<int>;
using usll = unordered_set<long long>;
using usc = unordered_set<char>;
 
 
int main()
{
   int t;
   cin>>t;
   while(t--)
   {
 
        int n;
        cin>>n;
        string s;
        cin>>s;
 
        vb a(n+1, false);
        int all=1;
        a[all]=true;
        for(int i=0;i<n;i++){
            if(s[all-1] == 'R')
            {
                all++;
            }
            else
            {
                all--;
            }
            a[all]=true;
        }
 
        int ans=0;
        for(int i=1;i<=n;i++)
        {
            if(a[i])
            {
                ans++;
            }
        }
 
        cout<<ans<<nl;
 
 
 
 
 
 
   }
 
}
