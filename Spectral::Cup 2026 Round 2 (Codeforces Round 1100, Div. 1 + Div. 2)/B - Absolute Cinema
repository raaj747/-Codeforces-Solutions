#include<bits/stdc++.h>
using namespace std;

typedef long long ll;
const char nl = '\n';
using vi = vector<int>;
using vll = vector<long long>;
using vs = vector<string>;
using si = set<int>;
using sll = set<long long>;
using st = stack<int>;

int main()
{
    int t;
    cin>>t;
    while(t--)
    {

        int n;
        cin>>n;

        vi a(n),b(n);
        for(int i=0;i<n;i++)
        {
            cin>>a[i];
        }

        for(int i=0;i<n;i++)
        {
            cin>>b[i];
        }

        ll sum=0;
        ll mx=0;

        for(int i=0;i<n;i++)
        {

            ll x= min(a[i],b[i]);
            ll y=max(a[i],b[i]);

            sum+=y;

            if(x>mx)
            {
                mx=x;
            }


        }

        ll ans=sum+mx;

        cout<<ans<<nl;






    }

}
