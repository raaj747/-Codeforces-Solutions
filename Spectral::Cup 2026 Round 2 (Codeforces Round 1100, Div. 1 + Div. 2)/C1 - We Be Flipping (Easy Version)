#include<bits/stdc++.h>
using namespace std;

typedef long long ll;
const char nl = '\n';
using vi = vector<int>;
using vll = vector<long long>;
using vs = vector<string>;
using si = set<int>;
using sll = set<long long>;
using st = stack<int>;

int main()
{
    int t;
    cin>>t;
    while(t--)
    {

        int n;
        cin>>n;

        vll a(n+1);
        for(int i=1;i<=n;i++)
        {
            cin>>a[i];
        }


        int cnt=0;
        vll v;
        for(int i=n;i>=1;i--)
        {

            ll x=a[i];
            if(cnt%2==1)
            {
                x=-x;
            }

            if(x>0)
            {
                v.push_back(i);
                cnt++;
            }


        }
        ll ans=v.size();
        cout<<ans<<nl;

        for(int i=0;i<v.size();i++)
        {
            cout<<v[i]<<" ";
        }

        cout<<nl;






    }

}
