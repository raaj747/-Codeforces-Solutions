#include<bits/stdc++.h>
using namespace std;

typedef long long ll;
const char nl = '\n';
using vi = vector<int>;
using vll = vector<long long>;
using vs = vector<string>;
using si = set<int>;
using sll = set<long long>;
using st = stack<int>;

int main()
{
    int t;
    cin>>t;
    while(t--)
    {

        int n,x,y;
        cin>>n>>x>>y;

        vi a(n+1);
        for(int i=0;i<n;i++)
        {
            cin>>a[i];
        }

        int g=__gcd(x,y);

        bool ok=true;
        for(int i=0;i<n;i++)
        {
            if(a[i]%g!=(i+1)%g)
            {
                ok=false;
                break;
            }


        }

        if(ok)
        {
            cout<<"YES"<<nl;
        }
        else
        {
            cout<<"NO"<<nl;
        }







    }

}
