#include<bits/stdc++.h>
using namespace std;

typedef long long ll;
const char nl = '\n';
using vi = vector<int>;
using vll = vector<long long>;
using vs = vector<string>;
using si = set<int>;
using sll = set<long long>;
using st = stack<int>;

int main()
{
    int t;
    cin>>t;
    while(t--)
    {

        ll n;
        cin>>n;

        vll a(n);
        for(int i=0;i<n;i++)
        {
            cin>>a[i];
        }

        //sort(a.begin(),a.end());

        bool ok=true;
        ll cnt=1;
        for(int i=0;i<n-1;i++)
        {
            if(a[i]<cnt)
            {
                ok=false;
                break;

            }
            a[i+1]+=a[i]-cnt;
            cnt++;

        }

        if(ok)
        {
            if(a[n-1]>=cnt)
            {
                cout<<"YES"<<nl;
            }
            else
            {
                cout<<"NO"<<nl;
            }


        }
        else
        {
            cout<<"NO"<<nl;
        }











    }

}
