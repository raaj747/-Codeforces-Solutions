#include<bits/stdc++.h>
using namespace std;

typedef long long ll;
const char nl = '\n';
using vi = vector<int>;
using vll = vector<long long>;
using vs = vector<string>;
using si = set<int>;
using sll = set<long long>;
using st = stack<int>;

int main()
{
    int t;
    cin>>t;
    while(t--)
    {
        int n;
        cin>>n;

        vi a(n);
        for(int i=0;i<n;i++)
        {
            cin>>a[i];
        }

        sort(a.begin(),a.end());

        int ans=n;
        for(int i=0;i<n;i++)
        {


            if(i&&a[i]==a[i-1])
            {
                continue;
            }

            int l=lower_bound(a.begin(),a.end(),a[i])-a.begin();
            int r=a.end()-upper_bound(a.begin(),a.end(),a[i]);

            ans=min(ans,max(l,r));



        }

        cout<<ans<<nl;






    }

}
