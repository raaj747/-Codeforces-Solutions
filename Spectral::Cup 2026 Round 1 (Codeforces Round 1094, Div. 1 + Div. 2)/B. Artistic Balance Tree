#include<bits/stdc++.h>
using namespace std;

typedef long long ll;
const char nl = '\n';
using vi = vector<int>;
using vll = vector<long long>;
using si = set<int>;
using sll = set<long long>;
using st = stack<int>;

int main()
{

    int t;
    cin>>t;
    while(t--)
    {
        ll n,m;
        cin>>n>>m;

        vll odd, even;
        ll total=0;

        for(int i=1;i<=n;i++)
        {
            ll x;
            cin>>x;
            total+=x;

            if(i%2==1)
                odd.push_back(x);
            else
                even.push_back(x);
        }

        ll cnt1=0;
        for(int i=0;i<m;i++)
        {
            int x;
            cin>>x;
            if(x%2==1)
              cnt1++;
        }

        ll cnt2=m-cnt1;

        sort(odd.rbegin(),odd.rend());
        sort(even.rbegin(),even.rend());

        ll k=0;

        ll size1=odd.size();
        ll mn=min(cnt1,size1);
        for(int i=0;i<mn && odd[i]>0;i++)
        {
            k+=odd[i];
        }
        if(mn>0 && !odd.empty() && odd[0]<=0)
        {
            k+=odd[0];
        }

        ll size2=even.size();
        mn=min(cnt2,size2);
        for(int i=0;i<mn && even[i]>0;i++)
        {
            k+=even[i];
        }

        if(mn>0 && !even.empty() && even[0]<=0)
        {
            k+=even[0];
        }


        ll res=total-k;

        cout<<res<<nl;







    }





}
